# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── Gemini AI (pick ONE option) ───────────────────────────────────────────────

# Option 1 — Simple API key (recommended, free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Option 2 — Vertex AI (GCP project + ADC / service account)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# VERTEX_MODEL=gemini-1.5-pro
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── GraphRAG ─────────────────────────────────────────────────────────────────
RAG_ENABLED=true
RAG_GRAPH_HOP_DEPTH=4          # max prerequisite nodes to retrieve per standard
RAG_MAX_SIBLINGS=5             # sibling standards included for domain context
RAG_MAX_EXISTING_QUESTIONS=5   # existing question stems injected for diversity
RAG_FULLTEXT_INDEX=standardsDescription  # Neo4j FTS index name
# Run POST /api/v1/rag/create-fulltext-index once after Neo4j starts

# ── PostgreSQL (async — matches Docker Compose defaults) ──────────────────────
DATABASE_URL=postgresql+asyncpg://ale_user:ale_pass@localhost:5433/ale_db

# ── Adaptive Agent ────────────────────────────────────────────────────────────
AGENT_MAX_QUESTIONS=10            # questions generated per assessment round
AGENT_MASTERY_THRESHOLD=0.7      # BKT P(mastered) below this = gap
AGENT_GAP_LIMIT=5                 # max gaps to remediate per round

# ── Student BKT ───────────────────────────────────────────────────────────────
STUDENT_INITIAL_MASTERY=0.1      # prior P(mastered) for new standards

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Adaptive Learning Engine
DEBUG=false
LOG_LEVEL=INFO
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── One-time data setup ───────────────────────────────────────────────────────
# After first docker compose up, run:
#   poetry run python scripts/import_learning_commons.py
# This loads ~144k StandardsFrameworkItem nodes + ~181k relationships into Neo4j.
